{
  "expo": {
    "name": "funcup",
    "slug": "funcup",
    "scheme": "funcup",
    "version": "0.1.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ]
    ],
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "funcup",
              "host": "q"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "funcup",
              "host": "q"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.anonymous.funcup"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.funcup"
    }
  }
}
