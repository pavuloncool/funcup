{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/dashboard/coffees/[id]",
      "regex": "^/dashboard/coffees/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/coffees/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/coffees/[id]/batches/new",
      "regex": "^/dashboard/coffees/([^/]+?)/batches/new(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/coffees/(?<nxtPid>[^/]+?)/batches/new(?:/)?$"
    },
    {
      "page": "/dashboard/coffees/[id]/batches/[batchId]",
      "regex": "^/dashboard/coffees/([^/]+?)/batches/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid",
        "nxtPbatchId": "nxtPbatchId"
      },
      "namedRegex": "^/dashboard/coffees/(?<nxtPid>[^/]+?)/batches/(?<nxtPbatchId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/q/[hash]",
      "regex": "^/q/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPhash": "nxtPhash"
      },
      "namedRegex": "^/q/(?<nxtPhash>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/dashboard/coffees",
      "regex": "^/dashboard/coffees(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/coffees(?:/)?$"
    },
    {
      "page": "/dashboard/coffees/new",
      "regex": "^/dashboard/coffees/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/coffees/new(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/pending",
      "regex": "^/pending(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pending(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}