# Default: cloud project (HTTPS — required for Expo Go on a physical device)
# Dashboard → Project Settings → API (NOT http://127.0.0.1:54323 — that is local Studio on your Mac only).
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local Supabase CLI / Docker:
#   • API + Edge Functions (scan_qr):  http://127.0.0.1:54321   ← use this in EXPO_PUBLIC_SUPABASE_URL
#   • Studio only (admin UI):        http://127.0.0.1:54323   ← do NOT point the mobile app here
#
# Keys: run `pnpm exec supabase status` from repo root and copy Project URL + Publishable key
# (older docs mention JWT anon — either works if your CLI still serves both).

# iOS Simulator on the same Mac as Docker:
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# --- Physical iPhone + local Docker + Expo Go ---
# Expo Go does NOT apply this repo's ios.infoPlist (NSAllowsLocalNetworking). Safari may load
# plain HTTP on your LAN while fetch() from Expo Go fails → Supabase shows e.g.
# "Could not send request to Edge Function".
#
# Working options:
#   A) Production/dev client build (recommended for LAN HTTP): from apps/consumer-mobile run
#        npx expo run:ios
#      Install on the phone; keep EXPO_PUBLIC_SUPABASE_URL=http://YOUR_MAC_LAN_IP:54321
#      (same machine IP you already use, port 54321).
#
#   B) Stay on Expo Go: point EXPO_PUBLIC_SUPABASE_URL at a hosted https://*.supabase.co project,
#      not local Docker.
#
# Note: libimobiledevice `iproxy` forwards Mac→device ports (like SSH to the phone), not
# Android-style adb reverse; it does not tunnel Mac Docker Supabase onto the phone's 127.0.0.1.

EXPO_PUBLIC_APP_URL=http://localhost:8081

# Base URL of Next.js roaster UI (apps/web); used to open /tag from the consumer app.
EXPO_PUBLIC_ROASTER_WEB_URL=http://localhost:3000
