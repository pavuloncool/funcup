{
  "name": "funcup",
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "phase004:readiness": "bash scripts/phase004-readiness-check.sh",
    "supabase:types": "echo \"Generate types via Supabase CLI: supabase gen types typescript --project-id <id> --schema public > supabase/types/database.ts\"",
    "test": "turbo run test",
    "consumer:start": "pnpm -C apps/consumer-mobile start",
    "consumer:ios": "pnpm -C apps/consumer-mobile ios",
    "consumer:web": "pnpm -C apps/consumer-mobile web",
    "consumer:web:clear": "pnpm -C apps/consumer-mobile run web -- -c",
    "consumer:prebuild": "pnpm -C apps/consumer-mobile run prebuild",
    "consumer:prebuild:clean": "pnpm -C apps/consumer-mobile run prebuild:clean",
    "postinstall": "node scripts/patch-metro-cache-exports.js",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "xmlbuilder": "15.0.0",
      "resolve": "1.22.10",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0"
  }
}
