{
  "name": "funcup",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "phase004:readiness": "bash scripts/phase004-readiness-check.sh",
    "supabase:types": "echo \"Generate types via Supabase CLI: supabase gen types typescript --project-id <id> --schema public > supabase/types/database.ts\"",
    "test": "turbo run test",
    "mobile:start": "pnpm -C apps/mobile start",
    "mobile:ios": "pnpm -C apps/mobile ios",
    "mobile:web": "pnpm -C apps/mobile web",
    "mobile:web:clear": "pnpm -C apps/mobile run web -- -c",
    "mobile:prebuild": "pnpm -C apps/mobile run prebuild",
    "mobile:prebuild:clean": "pnpm -C apps/mobile run prebuild:clean",
    "postinstall": "node scripts/patch-metro-cache-exports.js",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "xmlbuilder": "15.0.0",
      "resolve": "1.22.10",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0"
  }
}
